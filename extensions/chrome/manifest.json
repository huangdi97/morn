{
  "manifest_version": 3,
  "name": "Morn AI Assistant",
  "version": "1.0",
  "description": "AI-powered browsing assistant powered by Morn",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel"],
  "side_panel": { "default_path": "sidepanel.html" },
  "host_permissions": [
    "http://localhost:*/*",
    "ws://localhost:*/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:*/*"
    ]
  },
  "action": { "default_popup": "popup.html", "default_title": "Morn" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_end"
  }]
}
