{
  "name": "plugin-protocol-echo",
  "version": "1.0.0",
  "endpoints": [
    {
      "path": "/echo",
      "method": "POST",
      "description": "Echoes back the request body"
    },
    {
      "path": "/ping",
      "method": "GET",
      "description": "Returns pong"
    }
  ],
  "description": "An echo protocol plugin for testing MCP-style communication"
}